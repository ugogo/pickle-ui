{
  "name": "pickle-ui",
  "version": "0.0.0",
  "type": "module",
  "description": "React component library built with shadcn/ui, Tailwind CSS, and reui.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "shadcn",
    "tailwind",
    "reui"
  ],
  "author": "Ugo Onali",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "optionalDependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "reui": "^0.1.0",
    "tailwind-merge": "^2.3.0"
  }
}
