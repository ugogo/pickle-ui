{
  "$schema": "https://unpkg.com/release-it@20/schema/release-it.json",
  "git": {
    "changelog": "git log --pretty=format:\"- %s\" --no-merges ${from}...${to}",
    "requireCleanWorkingDir": true,
    "requireBranch": "main",
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}",
    "pushArgs": ["--follow-tags"]
  },
  "npm": {
    "publish": true
  },
  "github": {
    "release": true,
    "releaseName": "Pickle UI v${version}",
    "makeLatest": true
  },
  "hooks": {
    "before:init": ["pnpm run typecheck", "pnpm run test"]
  }
}
